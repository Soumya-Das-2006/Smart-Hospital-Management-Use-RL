# ─────────────────────────────────────────────────────────────────────────────
# Smart Hospital Resource Allocator — Environment Variables
#
# SETUP: Copy this file and fill in your values.
#   cp .env.example .env
#
# SECURITY RULES:
#   - NEVER commit .env to git (it is in .gitignore)
#   - NEVER hardcode these values in Python source files
#   - In production, set these as real environment variables or Docker secrets
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-strong-random-string-before-deploying

# Set to "true" only in local development — NEVER in production
FLASK_DEBUG=false

# Server
HOST=0.0.0.0
PORT=7860

# ── Session management ────────────────────────────────────────────────────────
SESSION_TTL_SECONDS=600     # Sessions idle longer than this are auto-purged (10 min)
MAX_SESSIONS=100            # Maximum concurrent sessions before 503 is returned

# ── LLM / HF Router (for inference.py) ───────────────────────────────────────
# Get your free token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# HF Router — routes to open models without individual API keys
API_BASE_URL=https://api-inference.huggingface.co/v1

# Model to use via HF Router
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ── Gunicorn (production) ─────────────────────────────────────────────────────
GUNICORN_WORKERS=2
